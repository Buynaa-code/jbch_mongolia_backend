{
  "permissions": {
    "allow": [
      "Bash(flutter:*)",
      "Bash(dart:*)",
      "Bash(flutter pub:*)",
      "Bash(dart pub:*)",
      "Bash(flutter build:*)",
      "Bash(flutter test:*)",
      "Bash(flutter analyze:*)",
      "Bash(flutter clean:*)",
      "Bash(dart fix:*)",
      "Bash(dart format:*)",
      "Bash(dart run build_runner:*)"
    ],
    "deny": []
  },
  "env": {
    "FLUTTER_ROOT": "${HOME}/flutter"
  }
}
