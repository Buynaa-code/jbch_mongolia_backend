# Server Configuration
NODE_ENV=development
PORT=5000

# MongoDB Connection
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/church_app
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/church_app?retryWrites=true&w=majority

# JWT Configuration
# IMPORTANT: Change these secrets in production!
JWT_ACCESS_SECRET=your_super_secure_access_secret_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
# Use comma-separated list for multiple origins or '*' for all
CORS_ORIGIN=http://localhost:3000
